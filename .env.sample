PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# --- Option A: Local MySQL (development) ---
# MYSQL_USER=root
# MYSQL_PASSWORD=your_local_password
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_DATABASE=credit_coop
# DATABASE_URL="mysql://root:your_local_password@127.0.0.1:3306/credit_coop"

# --- Option B: TiDB Cloud (hosted) ---
# 1. In TiDB Cloud console: Cluster -> Connect -> copy connection string
# 2. Create database "credit_coop" in TiDB console first
# 3. URL-encode special chars in password (@ -> %40, # -> %23)
# 4. Port is usually 4000; TLS is required: ?sslaccept=strict
TIDB_CLOUD=true
MYSQL_USER=YOUR_TIDB_USERNAME
MYSQL_PASSWORD=YOUR_TIDB_PASSWORD
MYSQL_HOST=YOUR_TIDB_HOST.tidbcloud.com
MYSQL_PORT=4000
MYSQL_DATABASE=credit_coop

# Example (replace placeholders with values from TiDB Cloud Connect dialog):
# DATABASE_URL="mysql://2abc123.root:MyP%40ssw0rd@gateway01.us-west-2.prod.aws.tidbcloud.com:4000/credit_coop?sslaccept=strict"
DATABASE_URL="mysql://YOUR_TIDB_USERNAME:YOUR_URL_ENCODED_PASSWORD@YOUR_TIDB_HOST:4000/credit_coop?sslaccept=strict"

ACCESS_TOKEN_SECRET=
REFRESH_TOKEN_SECRET=

EMAIL_PROVIDER=gmail
SENDER_EMAIL=
EMAIL_SECRET_KEY=

INTEREST_RATE=0.01
DEFAULT_COLLECTION=1000
